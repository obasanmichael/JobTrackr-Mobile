EXPO_PUBLIC_API_URL=http://YOUR_LAN_IP:4000/api/v1

# Web app origin for companion flows (billing checkout/portal opens in browser).
# EXPO_PUBLIC_WEB_APP_URL=http://YOUR_LAN_IP:3000

# Store submission, HTTPS URLs hosted before App Store / Play review (see docs/MOBILE_STORE_SUBMISSION.md).
# EXPO_PUBLIC_PRIVACY_POLICY_URL=https://example.com/privacy
# EXPO_PUBLIC_TERMS_OF_SERVICE_URL=https://example.com/terms
# EXPO_PUBLIC_ACCOUNT_DELETION_URL=https://example.com/delete-account
# EXPO_PUBLIC_SUPPORT_URL=https://example.com/support
# EXPO_PUBLIC_SUPPORT_EMAIL=support@example.com

# UI-only: skip login and show main tabs (fixtures). Omit for real auth.
# Ignored unless Metro is in development (__DEV__); release builds never scaffold.
# EXPO_PUBLIC_UI_SCAFFOLD_AUTH_SKIP=1
